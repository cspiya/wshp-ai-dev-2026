# Copy to .env and fill in. Never commit .env (gitignored).

# Neon Postgres connection string (Neon console → your project → Connect).
# On Vercel the Neon integration injects this automatically per environment/preview.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Required only after Neon Auth is provisioned (see SETUP-STATUS.md).
# NEON_AUTH_BASE_URL="https://..."
# NEON_AUTH_COOKIE_SECRET="generate-a-stable-secret-of-at-least-32-characters"
